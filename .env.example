# Required for movie metadata
OMDB_API_KEY=

# Optional: improves audience review coverage via TMDB
TMDB_API_READ_TOKEN=

# Optional: if added, you can replace local summarization with hosted LLM calls
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: if set, frontend calls dedicated backend (example: http://localhost:4000)
# If omitted, frontend falls back to Next.js API route /api/movie-insights
NEXT_PUBLIC_API_BASE_URL=
